# XenoComm MCP server — environment template.
#
# Copy this file to `mcp_server/.env` (which is git-ignored) and fill in values.
# The server auto-loads `mcp_server/.env` at startup. A real exported environment
# variable always takes precedence over the file.
#
#   cp mcp_server/.env.example mcp_server/.env
#   # then edit mcp_server/.env

# ---------------------------------------------------------------------------
# LLM-proposed protocol variants (M1 P2, via OpenRouter)
# ---------------------------------------------------------------------------
# Required to enable the `propose_variant_via_llm` tool. Without it, that tool
# returns a graceful "not configured" error and the rest of the server runs fine.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug (this is the default if unset). Any OpenRouter-hosted model works.
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Override only if you proxy OpenRouter. Default: https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# HTTP transport auth (S1) — only relevant when running with --http
# ---------------------------------------------------------------------------
# Bearer token required by the streamable-http transport. Leave unset for the
# default stdio transport.
# XENOCOMM_HTTP_TOKEN=

# ---------------------------------------------------------------------------
# Observability (E1)
# ---------------------------------------------------------------------------
# Directory for persisted gzip-JSONL flow logs. Persistence is off if unset.
# XENOCOMM_FLOW_LOG_DIR=./flow-logs
